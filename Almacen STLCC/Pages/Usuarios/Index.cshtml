@page
@model Almacen_STLCC.Pages.Usuarios.IndexModel
@{
    ViewData["Title"] = "Gestión de Usuarios";
}
<link rel="stylesheet" href="~/css/contraseña/Index.css" />

<div class="contenedor">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert-success">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert-danger">
            @TempData["ErrorMessage"]
        </div>
    }

    <div class="header">
        <h1>Gestión de Usuarios</h1>
        <a asp-page="/Usuarios/Create" class="btn-verde">Crear Usuario</a>
    </div>

    @if (Model.Usuarios.Any())
    {
        <table class="tabla-usuarios">
            <thead>
                <tr>
                    <th>Usuario</th>
                    <th>Rol</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var usuario in Model.Usuarios)
                {
                    <tr>
                        <td>@usuario.NombreUsuario</td>
                        <td>
                            @if (usuario.Rol == "ADMINISTRADOR")
                            {
                                <span class="badge-rol badge-admin">ADMINISTRADOR</span>
                            }
                            else
                            {
                                <span class="badge-rol badge-usuario">USUARIO</span>
                            }
                        </td>
                        <td class="acciones">
                            <a asp-page="/Usuarios/Edit"
                               asp-route-id="@usuario.Id_Usuario"
                               class="btn-editar">
                                Editar
                            </a>
                            <a asp-page="/Usuarios/ChangePassword"
                               asp-route-username="@usuario.NombreUsuario"
                               class="btn-cambiar">
                                Contraseña
                            </a>
                            <form method="post"
                                  asp-page-handler="Delete"
                                  asp-route-id="@usuario.Id_Usuario"
                                  style="display: inline;"
                                  onsubmit="return confirm('¿Estás seguro de eliminar el usuario \'@usuario.NombreUsuario\'?');">
                                <button type="submit" class="btn-eliminar">
                                    Eliminar
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="mensaje-vacio">
            No hay usuarios registrados en el sistema
        </div>
    }
</div>