@page
@model IndexModel
@{
    ViewData["Title"] = "Panel de Control - Almacén STLCC";
}

<link rel="stylesheet" href="~/css/Index.css"/>

<div class="contenedor">
    <header class="header">
        <h1>Sistema de Inventario - Almacén STLCC</h1>
        <img src="#" alt="Logo STLCC" />
        <p>Administra los productos, registra entradas y salidas, y genera reportes de manera eficiente.</p>
    </header>

    <section class="paneles">
        <div class="tarjetas">
            <div class="icono-productos">📦</div>
            <h3>Ver Productos</h3>
            <p>Consulta todos los productos registrados en el almacén.</p>
            <a asp-page="/Productos/Index" class="btn-productos">Ver Productos</a>
        </div>

        <div class="tarjetas">
            <div class="icono-crear">➕</div>
            <h3>Añadir Nuevo Producto</h3>
            <p>Registra un nuevo producto o servicio en el inventario.</p>
            <a asp-page="/Productos/Crear" class="btn-crear">Registrar Producto</a>
        </div>

        <div class="tarjetas">
            <div class="icono-editar">✏️</div>
            <h3>Modificar Productos</h3>
            <p>Edita o actualiza los datos de los productos existentes.</p>
            <a asp-page="/Productos/Editar" class="btn-editar">Modificar Producto</a>
        </div>

        <div class="tarjetas">
            <div class="icono-reportes">📊</div>
            <h3>Generar Reportes</h3>
            <p>Obtén reportes detallados de movimientos e inventario.</p>
            <a asp-page="/Reportes/Crear" class="btn-reportes">Generar Reportes</a>
        </div>

        <div class="tarjetas">
            <div class="icono-historial">🔁</div>
            <h3>Historial de Cambios</h3>
            <p>Consulta los registros de entradas y salidas del almacén.</p>
            <a asp-page="/Historial/Index" class="btn-historial">Ver Historial</a>
        </div>
    </section>
</div>