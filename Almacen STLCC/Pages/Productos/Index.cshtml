@page
@model Almacen_STLCC.Pages.Productos.IndexModel
@{
    ViewData["Title"] = "Productos - Almacén STLCC";
}
<link rel="stylesheet" href="~/css/productos/Index.css" />
<div class="contenedor">
    <header class="header">
        <div class="titulo-header">
            <div>
                <h1>📋 Lista de Productos</h1>
                <p>Consulta y gestiona todos los productos registrados en el inventario.</p>
            </div>
            <div class="prod-crear">
                <a asp-page="/CrearP/CrearP" class="btn-verde">➕ Añadir Producto</a>
            </div>
        </div>
    </header>
    <section class="tabla-productos">
        <table>
            <thead>
                <tr>
                    <th>Código</th>
                    <th>Nombre</th>
                    <th>Categoría</th>
                    <th>Unidad de Medida</th>
                    <th>Proveedor</th>
                    <th>Inventario Actual</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Productos != null && Model.Productos.Any())
                {
                    @foreach (var producto in Model.Productos)
                    {
                        <tr>
                            <td>@producto.Codigo_Producto</td>
                            <td>@producto.Nombre_Producto</td>
                            <td>@(producto.Categoria?.Nombre_Categoria ?? "Sin categoría")</td>
                            <td>@producto.Unidad_Medida</td>
                            <td>@(producto.Proveedor?.Nombre_Proveedor ?? "Sin proveedor")</td>
                            <td>
                                @if (Model.Inventarios != null && Model.Inventarios.ContainsKey(producto.Id_Producto))
                                {
                                    <span>@Model.Inventarios[producto.Id_Producto]</span>
                                }
                                else
                                {
                                    <span>0</span>
                                }
                            </td>
                            <td class="acciones">
                                <a asp-page="/Productos/Editar" asp-route-id="@producto.Id_Producto" class="btn-amarillo">Editar</a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="mensaje-vacio">No hay productos registrados.</td>
                    </tr>
                }
            </tbody>
        </table>
    </section>
</div>