@page
@model Almacen_STLCC.Pages.Productos.IndexModel
@{
    ViewData["Title"] = "Productos - Almacén STLCC";
}
<link rel="stylesheet" href="~/css/productos/Index.css" />
<div class="contenedor">
    <header class="header">
        <div class="titulo-header">
            <div>
                <h1><i class="fa-solid fa-clipboard-list"></i> Lista de Productos</h1>
                <p>Consulta y gestiona todos los productos registrados en el inventario.</p>
            </div>
            <div class="prod-crear">
                <a asp-page="/Productos/CrearP" class="btn-agregar"><i class="fa-solid fa-circle-plus"></i> Producto</a>
            </div>
        </div>
    </header>
    <section class="tabla-productos">
        <table>
            <thead>
                <tr>
                    <th>Código</th>
                    <th>Nombre</th>
                    <th>Marca</th>
                    <th>Categoría</th>
                    <th>Unidad de Medida</th>
                    <th>Proveedor(es)</th>
                    <th>Inventario Actual</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Productos != null && Model.Productos.Any())
                {
                    @foreach (var producto in Model.Productos)
                    {
                        <tr>
                            <td>@producto.Codigo_Producto</td>
                            <td>@producto.Nombre_Producto</td>
                            <td>@producto.Marca</td>
                            <td>@(producto.Categoria?.Nombre_Categoria ?? "Sin categoría")</td>
                            <td>@producto.Unidad_Medida</td>
                            <td>
                                @if (Model.ProveedoresPorProducto.ContainsKey(producto.Id_Producto) &&
                                                        Model.ProveedoresPorProducto[producto.Id_Producto].Any())
                                {
                                    <div style="font-size: 13px;">
                                        @foreach (var proveedor in Model.ProveedoresPorProducto[producto.Id_Producto])
                                        {
                                            <div style="margin-bottom: 3px;">• @proveedor</div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <span style="color: #999;">Sin proveedores</span>
                                }
                            </td>
                            <td>
                                @if (Model.Inventarios != null && Model.Inventarios.ContainsKey(producto.Id_Producto))
                                {
                                    <span>@Model.Inventarios[producto.Id_Producto]</span>
                                }
                                else
                                {
                                    <span>0</span>
                                }
                            </td>
                            <td class="acciones">
                                <a asp-page="/Productos/Editar"
                                   asp-route-id="@producto.Id_Producto"
                                   class="btn-editar">Editar</a>
                                <a asp-page="/Productos/GestionarProveedores"
                                   asp-route-id="@producto.Id_Producto"
                                   class="btn-proveedores">Proveedores</a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="mensaje-vacio">No hay productos registrados.</td>
                    </tr>
                }
            </tbody>
        </table>
    </section>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div id="successMessage" data-message="@TempData["SuccessMessage"]" style="display:none;"></div>
}

@section Scripts {
    <script src="~/js/productos/index.js"></script>
}