@page
@model Almacen_STLCC.Pages.Productos.CrearPModel
@{
    ViewData["Title"] = "Crear Producto";
}

<link rel="stylesheet" href="~/css/productos/crearp.css" />

<div class="modal-overlay" id="modalOverlay">
    <div class="modal-container">
        <div class="modal-header">
            <h2>Crear Nuevo Producto</h2>
            <button type="button" class="btn-close" id="btnClose">&times;</button>
        </div>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger">
                <i class="fa-solid fa-triangle-exclamation"></i> @Model.ErrorMessage
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
        {
            <div class="alert alert-success">
                <i class="fa-solid fa-check"></i> @Model.SuccessMessage
            </div>
        }

        <form method="post" id="formCrearProducto">
            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="Input.Codigo_Producto">Código del Producto:</label>
                    <input asp-for="Input.Codigo_Producto"
                           class="form-control"
                           type="number"
                           placeholder="Ej: 330996"
                           autocomplete="off"
                           autofocus />
                    <span asp-validation-for="Input.Codigo_Producto" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Input.Nombre_Producto">Nombre del Producto:</label>
                    <input asp-for="Input.Nombre_Producto"
                           class="form-control"
                           placeholder="Ej: Resma de papel bond"
                           autocomplete="off" />
                    <span asp-validation-for="Input.Nombre_Producto" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Input.Marca">Marca del Producto:</label>
                    <input asp-for="Input.Marca"
                           class="form-control"
                           placeholder="Ej: Chamex"
                           autocomplete="off" />
                    <span asp-validation-for="Input.Marca" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Input.Id_Categoria">Categoría:</label>
                    <select asp-for="Input.Id_Categoria" class="form-select" id="selectCategoria">
                        <option value="">-- Seleccione una categoría --</option>
                        @foreach (var categoria in Model.Categorias)
                        {
                            <option value="@categoria.Id_Categoria">@categoria.Nombre_Categoria</option>
                        }
                    </select>
                    <span asp-validation-for="Input.Id_Categoria" class="text-danger"></span>
                    <button type="button" class="btn-link-crear" id="btnCrearCategoria">
                        <i class="fa-solid fa-plus"></i> Crear nueva categoría
                    </button>
                </div>

                <div class="form-group">
                    <label asp-for="Input.Unidad_Medida">Unidad de Medida:</label>
                    <input asp-for="Input.Unidad_Medida"
                           class="form-control"
                           placeholder="Ej: Paquete"
                           autocomplete="off" />
                    <span asp-validation-for="Input.Unidad_Medida" class="text-danger"></span>
                </div>

                <div class="form-group full-width">
                    <label>Proveedor(es):</label>
                    <div class="proveedores-container">
                        <div class="proveedores-chips" id="proveedoresChips"></div>
                        <div class="proveedores-agregar">
                            <button type="button" class="btn-agregar-proveedor" id="btnAgregarProveedor">
                                <i class="fa-solid fa-plus"></i>
                            </button>
                        </div>
                    </div>
                    <input type="hidden" id="hiddenProveedores" name="Input.Id_Proveedor" />
                    <div class="dropdown-proveedores" id="dropdownProveedores" style="display: none;">
                        <input type="text"
                               class="search-proveedor"
                               id="searchProveedor"
                               placeholder="Buscar proveedor..." />
                        <div class="lista-proveedores" id="listaProveedores">
                            @foreach (var proveedor in Model.Proveedores)
                            {
                                <div class="proveedor-item"
                                     data-id="@proveedor.Id_Proveedor"
                                     data-nombre="@proveedor.Nombre_Proveedor">
                                    @proveedor.Nombre_Proveedor
                                </div>
                            }
                        </div>
                        <div class="dropdown-footer">
                            <button type="button" class="btn-crear-nuevo-proveedor">
                                <i class="fa-solid fa-plus"></i> Crear nuevo proveedor
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="form-actions">
                <button type="button" class="btn-guardar" id="btnGuardar">
                    <i class="fa-solid fa-floppy-disk"></i> Guardar Producto
                </button>
                <button type="button" class="btn-cancelar" id="btnCancelar">
                    <i class="fa-solid fa-ban"></i> Cancelar
                </button>
            </div>
        </form>
    </div>
</div>

<script>
    window.proveedoresData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                Model.Proveedores.Select(p => new { id = p.Id_Proveedor, nombre = p.Nombre_Proveedor })
        ));
</script>

@section Scripts {
    <script src="~/js/productos/crearp.js"></script>
}