@page "{id:int}"
@model Almacen_STLCC.Pages.Actas.ArchivosModel
@{
    ViewData["Title"] = $"Archivos del Acta {Model.Acta?.F01 ?? "N/A"}";
}
<link rel="stylesheet" href="~/css/actas/archivos.css" />

<div class="contenedor">
    <header class="header">
        <div>
            <h1><i class="fa-solid fa-paperclip"></i> Archivos del Acta</h1>
            <p>F01: @(Model.Acta?.F01 ?? "N/A") - @(Model.Acta?.Proveedor?.Nombre_Proveedor ?? "N/A")</p>
        </div>
        <a asp-page="/Actas/Index" class="btn-volver"><i class="fa-solid fa-angle-left"></i> Volver a Actas</a>
    </header>

    @if (Model.Anexos != null && Model.Anexos.Any())
    {
        <section class="tabla-archivos">
            <div class="header-archivos">
                <h2>Archivos Adjuntos (@Model.Anexos.Count)</h2>
                <button type="button" class="btn-subir" onclick="mostrarFormulario()">
                    <i class="fa-solid fa-circle-plus"></i> Subir Nuevo Archivo
                </button>
            </div>

            <table>
                <thead>
                    <tr>
                        <th>Nombre del Archivo</th>
                        <th>Formato</th>
                        <th>Peso</th>
                        <th>Fecha de Subida</th>
                        <th>Enlace</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var anexo in Model.Anexos)
                    {
                        <tr>
                            <td>@anexo.Nombre_Archivo</td>
                            <td><span class="badge-formato">@anexo.Tipo_Archivo?.ToUpper() ?? "N/A"</span></td>
                            <td>@anexo.Tamaño_Kb KB</td>
                            <td>@anexo.Fecha_Subida.ToString("dd/MM/yyyy")</td>
                            <td>
                                <a asp-page-handler="Descargar"
                                   asp-route-id="@anexo.Id_Anexo"
                                   class="btn-descargar"
                                   target="_blank">
                                    <i class="fa-solid fa-download"></i> Descargar
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </section>
    }
    else
    {
        <section class="sin-archivos">
            <div class="mensaje-vacio">
                <p><i class="fa-regular fa-folder-open"></i> Aún no hay archivos adjuntos.</p>
                <p>Si desea subir un archivo, <a href="javascript:void(0)" onclick="mostrarFormulario()" class="link-destacado">haga clic aquí</a></p>
            </div>
        </section>
    }

    <div id="formularioSubida" class="formulario-subida" style="display: none;">
        <div class="formulario-container">
            <h3>Subir Archivo</h3>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger">@Model.ErrorMessage</div>
            }

            <form method="post" enctype="multipart/form-data" id="formArchivo">
                <input type="hidden" name="IdActa" value="@(Model.Acta?.Id_Acta ?? 0)" />

                <div class="dropzone" id="dropzone">
                    <div class="dropzone-content">
                        <p><i class="fa-solid fa-file-arrow-up"></i> Arrastre su archivo aquí</p>
                        <p>o</p>
                        <label for="inputArchivo" class="btn-seleccionar">Seleccionar archivo</label>
                        <input type="file"
                               id="inputArchivo"
                               name="Archivo"
                               accept=".jpg,.jpeg,.png,.pdf,.doc,.docx"
                               style="display: none;"
                               onchange="mostrarNombreArchivo(this)" />
                        <p class="archivo-seleccionado" id="archivoSeleccionado"></p>
                        <small>Formatos permitidos: JPG, PNG, PDF, DOC, DOCX (tamaño máximo 10 MB)</small>
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn-guardar"><i class="fa-solid fa-floppy-disk"></i> Subir Archivo</button>
                    <button type="button" class="btn-cancelar" onclick="ocultarFormulario()">Cancelar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="~/js/actas/archivos.js"></script>